{
  "name": "@naldadev/chat",
  "version": "0.1.0",
  "description": "Framework-agnostic real-time web chat SDK — a WebSocket client with auto-reconnect, heartbeat, and a Zod-validated protocol shared by client and server.",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.2",
    "zod": "^4.4.3"
  },
  "keywords": [
    "chat",
    "websocket",
    "realtime",
    "sdk",
    "cloudflare",
    "durable-objects",
    "zod",
    "typescript"
  ],
  "license": "MIT",
  "author": "박성재 (NALDA) <naldadev@gmail.com>",
  "homepage": "https://github.com/FLY2ED/carrot-chat/tree/main/packages/chat#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FLY2ED/carrot-chat.git",
    "directory": "packages/chat"
  },
  "bugs": {
    "url": "https://github.com/FLY2ED/carrot-chat/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
