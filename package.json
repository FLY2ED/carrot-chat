{
  "name": "carrot-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "재사용 가능한 웹채팅 SDK 데모 — React + TypeScript + Cloudflare Durable Objects(WebSocket)",
  "scripts": {
    "dev": "vite dev",
